import os
import json
import httpx
from datetime import datetime
from stripe_handler import (
    creer_client, creer_lien_paiement, creer_abonnement,
    annuler_abonnement, get_abonnement, lister_abonnements_actifs,
    verifier_webhook, statut_abonnement, prochaine_facturation, stripe_ok
)

SUPABASE_URL = os.environ.get("SUPABASE_URL", "")
SUPABASE_KEY = os.environ.get("SUPABASE_KEY", "")
STRIPE_PRICE_ID = os.environ.get("STRIPE_PRICE_ID", "")
TWILIO_FROM = os.environ.get("TWILIO_FROM", "")
TWILIO_SID = os.environ.get("TWILIO_SID", "")
TWILIO_TOKEN = os.environ.get("TWILIO_TOKEN", "")

def get_headers_sb():
    return {
        "apikey": SUPABASE_KEY,
        "Authorization": "Bearer " + SUPABASE_KEY,
        "Content-Type": "application/json",
        "Prefer": "return=representation"
    }

# ──────────────────────────────────────────────
# GESTION CLIENTS NOVA
# ──────────────────────────────────────────────

def creer_client_nova(nom: str, email: str, tel: str, pizzeria: str) -> dict | None:
    try:
        # 1. Creer client dans Stripe
        stripe_customer = creer_client(nom, email, tel, pizzeria)
        if not stripe_customer:
            return None

        # 2. Generer lien de paiement
        lien = creer_lien_paiement(STRIPE_PRICE_ID, pizzeria, email)

        # 3. Sauvegarder dans Supabase
        client_data = {
            "nom": nom,
            "email": email,
            "telephone": tel,
            "pizzeria": pizzeria,
            "stripe_customer_id": stripe_customer.get("id", ""),
            "statut": "en_attente_paiement",
            "lien_paiement": lien or "",
            "created_at": datetime.now().isoformat()
        }

        if SUPABASE_URL and SUPABASE_KEY:
            r = httpx.post(
                SUPABASE_URL + "/rest/v1/clients_nova",
                headers=get_headers_sb(),
                json=client_data,
                timeout=10
            )
            if r.status_code in [200, 201]:
                client_data["id"] = r.json()[0].get("id")

        client_data["lien_paiement"] = lien
        return client_data

    except Exception as e:
        print("Erreur creer_client_nova : " + str(e))
        return None


def get_clients_actifs() -> list:
    if not (SUPABASE_URL and SUPABASE_KEY):
        return []
    try:
        r = httpx.get(
            SUPABASE_URL + "/rest/v1/clients_nova?statut=eq.actif&order=created_at.desc",
            headers=get_headers_sb(),
            timeout=10
        )
        return r.json() if r.status_code == 200 else []
    except Exception as e:
        print("Erreur get_clients_actifs : " + str(e))
        return []


def activer_client(stripe_customer_id: str, subscription_id: str):
    if not (SUPABASE_URL and SUPABASE_KEY):
        return
    try:
        httpx.patch(
            SUPABASE_URL + "/rest/v1/clients_nova?stripe_customer_id=eq." + stripe_customer_id,
            headers=get_headers_sb(),
            json={
                "statut": "actif",
                "stripe_subscription_id": subscription_id,
                "activated_at": datetime.now().isoformat()
            },
            timeout=10
        )
        print("Client active : " + stripe_customer_id)
    except Exception as e:
        print("Erreur activer_client : " + str(e))


def desactiver_client(stripe_customer_id: str):
    if not (SUPABASE_URL and SUPABASE_KEY):
        return
    try:
        httpx.patch(
            SUPABASE_URL + "/rest/v1/clients_nova?stripe_customer_id=eq." + stripe_customer_id,
            headers=get_headers_sb(),
            json={"statut": "inactif", "deactivated_at": datetime.now().isoformat()},
            timeout=10
        )
        print("Client desactive : " + stripe_customer_id)
    except Exception as e:
        print("Erreur desactiver_client : " + str(e))


def send_whatsapp_notification(tel: str, message: str):
    try:
        from twilio.rest import Client
        client = Client(TWILIO_SID, TWILIO_TOKEN)
        client.messages.create(
            body=message,
            from_="whatsapp:" + TWILIO_FROM,
            to="whatsapp:" + tel
        )
    except Exception as e:
        print("Erreur WhatsApp notification : " + str(e))
