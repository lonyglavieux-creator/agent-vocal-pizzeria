def creer_lien_paiement(price_id: str, pizzeria: str = "", email: str = "") -> str | None:
    if not stripe_ok():
        return None
    try:
        data = {
            "line_items[0][price]": price_id,
            "line_items[0][quantity]": "1",
            "mode": "subscription",
            "success_url": "https://web-production-967e41.up.railway.app/paiement/succes?session_id={CHECKOUT_SESSION_ID}",
            "cancel_url": "https://web-production-967e41.up.railway.app/paiement/annule",
            "metadata[pizzeria]": pizzeria,
            "allow_promotion_codes": "true"
        }
        if email:
            data["customer_email"] = email

        r = httpx.post(
            STRIPE_API + "/checkout/sessions",
            headers=stripe_headers(),
            data=data,
            timeout=10
        )
        if r.status_code == 200:
            url = r.json().get("url", "")
            print("Lien paiement cree : " + url[:50])
            return url
        print("Erreur lien paiement : " + r.text)
        return None
    except Exception as e:
        print("Erreur creer_lien_paiement : " + str(e))
        return None

