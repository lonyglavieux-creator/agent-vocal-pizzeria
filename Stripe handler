def verifier_webhook(payload: bytes, signature: str) -> dict | None:
    try:
        import hmac
        import hashlib
        parts = {}
        for item in signature.split(","):
            k, v = item.split("=", 1)
            parts[k] = v
        timestamp = parts.get("t", "")
        sig = parts.get("v1", "")
        signed_payload = timestamp + "." + payload.decode("utf-8")
        expected = hmac.new(
            STRIPE_WEBHOOK_SECRET.encode(),
            signed_payload.encode(),
            hashlib.sha256
        ).hexdigest()
        if hmac.compare_digest(expected, sig):
            import json
            return json.loads(payload)
        return None
    except Exception as e:
        print("Erreur webhook verification : " + str(e))
        return None

def statut_abonnement(subscription: dict) -> str:
    statut = subscription.get("status", "")
    if statut == "active":
        return "actif"
    elif statut == "past_due":
        return "en_retard"
    elif statut == "canceled":
        return "annule"
    elif statut == "trialing":
        return "essai"
    return statut

def prochaine_facturation(subscription: dict) -> str:
    ts = subscription.get("current_period_end", 0)
    if ts:
        dt = datetime.fromtimestamp(ts)
        return dt.strftime("%d/%m/%Y")
    return "inconnue"
