def creer_abonnement(customer_id: str, price_id: str) -> dict | None:
    if not stripe_ok():
        return None
    try:
        data = {
            "customer": customer_id,
            "items[0][price]": price_id,
            "payment_behavior": "default_incomplete",
            "expand[]": "latest_invoice.payment_intent"
        }
        r = httpx.post(STRIPE_API + "/subscriptions", headers=stripe_headers(), data=data, timeout=10)
        if r.status_code == 200:
            print("Abonnement cree : " + r.json().get("id", ""))
            return r.json()
        print("Erreur Stripe abonnement : " + r.text)
        return None
    except Exception as e:
        print("Erreur creer_abonnement : " + str(e))
        return None

def annuler_abonnement(subscription_id: str) -> bool:
    if not stripe_ok():
        return False
    try:
        r = httpx.delete(
            STRIPE_API + "/subscriptions/" + subscription_id,
            headers=stripe_headers(),
            timeout=10
        )
        return r.status_code == 200
    except Exception as e:
        print("Erreur annuler_abonnement : " + str(e))
        return False

def get_abonnement(subscription_id: str) -> dict | None:
    if not stripe_ok():
        return None
    try:
        r = httpx.get(
            STRIPE_API + "/subscriptions/" + subscription_id,
            headers=stripe_headers(),
            timeout=10
        )
        return r.json() if r.status_code == 200 else None
    except Exception as e:
        print("Erreur get_abonnement : " + str(e))
        return None

def lister_abonnements_actifs() -> list:
    if not stripe_ok():
        return []
    try:
        r = httpx.get(
            STRIPE_API + "/subscriptions?status=active&limit=100",
            headers=stripe_headers(),
            timeout=10
        )
        if r.status_code == 200:
            return r.json().get("data", [])
        return []
    except Exception as e:
        print("Erreur lister_abonnements : " + str(e))
        return []

