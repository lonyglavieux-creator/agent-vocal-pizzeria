import os
import httpx
from datetime import datetime, timedelta

STRIPE_SECRET_KEY = os.environ.get("STRIPE_SECRET_KEY", "")
STRIPE_WEBHOOK_SECRET = os.environ.get("STRIPE_WEBHOOK_SECRET", "")
PRIX_MENSUEL = os.environ.get("STRIPE_PRICE_ID", "")

STRIPE_API = "https://api.stripe.com/v1"

def stripe_headers():
    return {
        "Authorization": "Bearer " + STRIPE_SECRET_KEY,
        "Content-Type": "application/x-www-form-urlencoded"
    }

def stripe_ok() -> bool:
    return bool(STRIPE_SECRET_KEY)

# ──────────────────────────────────────────────
# CLIENTS
# ──────────────────────────────────────────────

def creer_client(nom: str, email: str, tel: str = "", pizzeria: str = "") -> dict | None:
    if not stripe_ok():
        return None
    try:
        data = {
            "name": nom,
            "email": email,
            "phone": tel,
            "metadata[pizzeria]": pizzeria,
            "metadata[source]": "nova_ai"
        }
        r = httpx.post(STRIPE_API + "/customers", headers=stripe_headers(), data=data, timeout=10)
        if r.status_code == 200:
            print("Client Stripe cree : " + r.json().get("id", ""))
            return r.json()
        print("Erreur Stripe client : " + r.text)
        return None
    except Exception as e:
        print("Erreur creer_client : " + str(e))
        return None

def get_client(customer_id: str) -> dict | None:
    if not stripe_ok():
        return None
    try:
        r = httpx.get(STRIPE_API + "/customers/" + customer_id, headers=stripe_headers(), timeout=10)
        return r.json() if r.status_code == 200 else None
    except Exception as e:
        print("Erreur get_client : " + str(e))
        return None

# ──────────────────────────────────────────────
# ABONNEMENTS
